define _start() {

    </
    IMPORTANT
    This will not run unless you
    use --use-classic-booleans
    />

    bool isCool = True      ?? Tokenized to BOOL1
    bool hungry = False     ?? Tokenized to BOOL0

    if isCool then {
        println("You are Cool")
    }
    if hungry == True then {
        println("You are hungry")
    }
}
define factorial(int n) {

    if n == 0 then {
        return 1
    }

    return n * factorial(n - 1)
}

define _start() {
    int num = int(input("Enter a number: "))
    int fac = factorial(num)
    print(num)
    print("! = ")
    println(fac)
